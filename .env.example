# HULLAR ortam değişkenleri — bunu kopyala, adını .env yap, kendi bilgilerini gir
AI_BACKEND=ollama
OPENROUTER_API_KEY=buraya_kendi_openrouter_keyin
OPENROUTER_MODEL=google/gemini-3.5-flash
VISION_MODEL=moondream
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=aya-expanse:8b
OLLAMA_CODER_MODEL=qwen2.5-coder:7b
USER_NAME=YourName
# Telegram bilgisi data/telegram.json içine: {"bot_token":"...","chat_id":123}
